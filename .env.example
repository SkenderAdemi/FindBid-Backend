# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Auth (optional): secret for JWT or token validation. Leave empty to accept any Bearer token.
AUTH_SECRET=

# OpenAI (optional): for AI refine endpoint POST /v1/ai/refine (gpt-4o-mini)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# MySQL + Prisma (required for the API to run)
# Local MySQL:   mysql://USER:PASSWORD@localhost:3306/DATABASE_NAME
# TiDB Cloud (requires TLS): add ?sslaccept=strict to the URL, e.g.:
#   mysql://USER:PASSWORD@HOST:4000/DATABASE_NAME?sslaccept=strict
DATABASE_URL=
