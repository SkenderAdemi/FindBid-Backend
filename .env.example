# Server
PORT=3001
NODE_ENV=development

# Real-time: WebSocket on the same port as HTTP — ws://host:PORT/v1/ws (or wss:// behind TLS)

# CORS (comma-separated; https://find-bid.vercel.app is always allowed)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Auth (optional): secret for JWT or token validation. Leave empty to accept any Bearer token.
AUTH_SECRET=

# Firebase Admin (optional): verifies frontend ID tokens and sets req.userId / req.userName)
# Option A: path to service account JSON file (e.g. ./firebase-service-account.json)
#   GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Option B: raw JSON string (e.g. for serverless) — set FIREBASE_SERVICE_ACCOUNT_JSON to the full JSON
#   FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Get the key: Firebase Console → Project settings → Service accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=

# OpenAI (optional): for AI refine endpoint POST /v1/ai/refine (gpt-4o-mini)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# MySQL + Prisma (required for the API to run)
# Local MySQL:   mysql://USER:PASSWORD@localhost:3306/DATABASE_NAME
# TiDB Cloud (requires TLS): add ?sslaccept=strict to the URL, e.g.:
#   mysql://USER:PASSWORD@HOST:4000/DATABASE_NAME?sslaccept=strict
DATABASE_URL=
