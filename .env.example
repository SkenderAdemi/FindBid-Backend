# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Auth (optional): secret for JWT or token validation. Leave empty to accept any Bearer token.
AUTH_SECRET=

# OpenAI (optional): for AI refine endpoint POST /v1/ai/refine (gpt-4o-mini)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Database (fill when you add a real DB)
# DATABASE_URL=postgresql://user:pass@localhost:5432/findbid
# DATABASE_URL=sqlite:./data/findbid.sqlite
